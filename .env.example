# Database (Railway PostgreSQL)
DATABASE_URL=postgresql+asyncpg://pm:pm@localhost:5434/pm_assistant

# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_LIFF_ID=your_liff_id
LINE_LOGIN_CHANNEL_ID=your_line_login_channel_id

# Security
APP_ENCRYPTION_KEY=change-me-32-bytes-minimum-secret!!
JWT_SECRET=change-me-jwt-secret

# LLM — default Gemini (free: https://aistudio.google.com/apikey)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI fallback (optional, set LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OAuth (Google / Jira / ClickUp)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=

# App
APP_ENV=development
APP_BASE_URL=http://localhost:8000
CONFIRMATION_TIMEOUT_MINUTES=30
RICH_MENU_AUTO_SETUP=true

# Optional: secret for POST /v1/admin/rich-menu/setup (defaults to JWT_SECRET)
SETUP_SECRET=
